			            CALCULATE (
			                SUM ( g_bowler_backorder[DistroBOValue] ),
			                g_bowler_backorder[SnapshotDate] = _LastSnapDate
			            ),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_backorder[DistroBOQty] ),
			                g_bowler_backorder[SnapshotDate] = _LastSnapDate
			            )
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
			
