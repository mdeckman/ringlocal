	measure 'Inventory DIOH' = ```
			
			VAR _Inv  = [Inventory Unrestricted Dynamic]   -- stock level (same scale as forecast)
			VAR _Fcst = [Forecast Supply Dynamic test]         -- forecast over the selected period
			VAR _Days = [Working Days (Selected, Total)]  -- or calendar days, depending on your logic
			RETURN
			IF(
			    ISBLANK(_Inv) || ISBLANK(_Fcst) || _Fcst <= 0 || _Days <= 0,
			    BLANK(),
			    DIVIDE( _Inv * _Days, _Fcst )             -- = Inventory / (Forecast / Days)
