	measure 'Order Shipped Period (Ext)' = ```
			
			-- OrderCreateDate ≤ max selected; RequestedDeliveryDate within selected window
			
			VAR _minSel =
			    CALCULATE ( MIN ( 'g_dimdate_analytics_ipd'[CalendarDate] ), ALLSELECTED ( 'g_dimdate_analytics_ipd'[CalendarDate] ) )
			VAR _maxSel =
			    CALCULATE ( MAX ( 'g_dimdate_analytics_ipd'[CalendarDate] ), ALLSELECTED ('g_dimdate_analytics_ipd'[CalendarDate] ) )
			RETURN
			CALCULATE (
			    [Order Shipped Dynamic (Ext)],
			    REMOVEFILTERS ( g_bowler_orders[RequestedDeliveryDate], g_bowler_orders[CreateDate] ),
			    KEEPFILTERS ( g_bowler_orders[CreateDate] <= _maxSel ),
			    KEEPFILTERS ( g_bowler_orders[RequestedDeliveryDate] >= _minSel && g_bowler_orders[RequestedDeliveryDate] <= _maxSel )
			)
			
			```
		formatString: #,0
		displayFolder: Dynamic Measures - Supply
		lineageTag: c6776020-e998-46b9-b04c-e6fdb71d820f

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'BO Dist. Dynamic' = ```
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR _LastSnapDate =
			    CALCULATE (
			        MAX ( g_bowler_backorder[SnapshotDate] ),
			        REMOVEFILTERS ( g_bowler_backorder[SnapshotDate] ),
			        DATEVALUE ( g_bowler_backorder[SnapshotDate] ) <= _TargetDate
			    )
			VAR _Base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			        "Revenue",
			            CALCULATE (
			                SUM ( g_bowler_backorder[DistroBOValue2] ),
			                g_bowler_backorder[SnapshotDate] = _LastSnapDate
			            ),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_backorder[DistroBOQty] ),
			                g_bowler_backorder[SnapshotDate] = _LastSnapDate
			            )
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
			
			```
		formatString: #,0
		displayFolder: Dynamic Measures - Supply
		lineageTag: dbfd91a5-87b1-48c5-a032-b7e7ded2426a

		annotation PBI_FormatHint = {"isDecimal":true}

