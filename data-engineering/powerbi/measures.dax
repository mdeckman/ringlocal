	measure 'Run-Rate % Flag' = ```
			
			VAR p = [Run-Rate Forecast vs Budget % (Selection)]
			RETURN
			IF(
			    ISBLANK(p),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        p >= 1.00, "🟢 Healthy",
			        p >= 0.95, "🟡 Watch-Out",
			                 "🔴 Critical"
			    )
			)
			
			```
		displayFolder: Flag
		lineageTag: 6bbf1d9b-22ce-4875-b7c9-a28110ea49f4

	measure 'General Status Flag Text Color' =
			
			VAR _flag = [Run-Rate % Flag]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(_flag), "#808080",         -- grey for no value
			    CONTAINSSTRING(_flag, "Healthy"),   "#3D5C28",   -- deep green
			    CONTAINSSTRING(_flag, "Watch-Out"), "#7A5C00",   -- muted amber
			    CONTAINSSTRING(_flag, "Critical"),  "#B23E3E",   -- deep red
			    "#808080"                           -- fallback grey
			)
		displayFolder: Flag
		lineageTag: 7ba9d141-1a4a-49d5-b064-5b8b5eaf015e

	measure 'General Status Flag Background Color' = ```
			
			VAR _flag = [Run-Rate % Flag]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(_flag), "#F2F2F2",          -- light grey for no value
			    CONTAINSSTRING(_flag, "Healthy"),   "#BEDC96",   -- soft green
			    CONTAINSSTRING(_flag, "Watch-Out"), "#FFE9A3",   -- soft yellow
			    CONTAINSSTRING(_flag, "Critical"),  "#F0A0A0",   -- soft red
			    "#F2F2F2"                           -- fallback grey
			)
			
			```
