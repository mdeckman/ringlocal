	measure 'Billing Dynamic' = ```
			
			VAR _base =
			
			VAR metric = SELECTEDVALUE ( 'slc_Metric'[Metric] )
			RETURN
			SWITCH (
			    TRUE (),
			
			    metric = "Revenue",
			        CALCULATE (
			            SUM ( g_bowler_billing_master_ww_ipd[Actual Net Revenue USD] ),
			            KEEPFILTERS ( g_bowler_billing_master_ww_ipd[Sales Flag] = BLANK() ),
			            KEEPFILTERS ( g_bowler_billing_master_ww_ipd[Direct Sales View Flag] = TRUE () )
			        ),
			
			    metric = "Units",
			        SUM ( g_bowler_billing_master_ww_ipd[Billing Quantity] ),
			
			    BLANK ()
			)
			
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1",     _base,
			        "/1000",  DIVIDE ( _base, 1000 ),
			        "M",      _base / 1000000,
			        _base     -- default if nothing selected
			    )
			
			```
