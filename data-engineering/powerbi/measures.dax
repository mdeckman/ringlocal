	measure 'Forecast Supply Dynamic' = ```
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[DateKeySPLY])
			VAR _LastSnapDate =
			    CALCULATE (
			        MAX ( g_bowler_fcst[SnapshotDate]),
			        REMOVEFILTERS ( g_bowler_fcst[SnapshotDate]),
			        DATEVALUE ( g_bowler_fcst[SnapshotDate]) <= _TargetDate
			    )
			VAR _Base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			        "Revenue",
			            BLANK(),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_fcst[ConsensuFinalForecast] ),
			                 g_bowler_fcst[SnapshotDate] = _LastSnapDate
			            )
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
			
			```
