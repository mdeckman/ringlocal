	measure 'fmt Perf prj Font Color' =
			
			VAR _p =
			    [Fin. Gap Actual to PRJ]          // <-- replace with your measure
			RETURN
			SWITCH (
			    TRUE(),
			    ISBLANK(_p), BLANK(),
			    _p < 0, "#B23E3E",     // red text
			    _p > 0, "#3D5C28",     // green text
			    BLANK()                // exactly 100%: no override
			)
