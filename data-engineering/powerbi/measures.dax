	measure 'Latest Closed - Target Supply Back Order' = ```
			
			VAR _LatestClosedMonth =
			    CALCULATE (
			        MAX ( g_dimdate_analytics_ipd[CalendarDate] ),
			        FILTER (
			            ALL ( g_dimdate_analytics_ipd ),
			            g_dimdate_analytics_ipd[IsClosedMonth] = TRUE ()
			                && g_dimdate_analytics_ipd[CalendarDate] <= TODAY ()
			        )
			    )
			RETURN
			CALCULATE (
			    [Target Helper Supply Back Order] * [Fin. Projection Scenario Dynamic],
			    g_dimdate_analytics_ipd[CalendarDate] = _LatestClosedMonth
			)
			
