	measure 'Supply SIOP YTG' = ```
			
			VAR _selFY        = MAX ( 'g_dimdate_analytics_ipd'[FiscalYear] )
			VAR _lastSelDate  = EOMONTH ( MAX ( 'g_dimdate_analytics_ipd'[CalendarDate] ), 0 )
			VAR _fyEndDate    =
			    CALCULATE (
			        MAX ( 'g_dimdate_analytics_ipd'[CalendarDate] ),
			        ALL ( 'g_dimdate_analytics_ipd' ),
			        'g_dimdate_analytics_ipd'[FiscalYear] = _selFY
			    )
			RETURN
			CALCULATE (
			    DIVIDE (
			        [Forecast Supply Dynamic] - [Fin. Projection Scenario Dynamic],
			        [Fin. Projection Scenario Dynamic],
			        0
			    ),
			    FILTER (
			        ALL ( 'g_dimdate_analytics_ipd' ),
			        'g_dimdate_analytics_ipd'[FiscalYear] = _selFY
			            && 'g_dimdate_analytics_ipd'[CalendarDate] > _lastSelDate
			            && 'g_dimdate_analytics_ipd'[CalendarDate] <= _fyEndDate
			    )
			)
			
			```
		displayFolder: Dynamic Measures - Supply
		lineageTag: 15947fb7-dfc6-485f-a47a-962da578b806

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'BO Supply Revenue' = ```
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[DateKeySPLY] )
			VAR _LastSnapDate =
			    CALCULATE (
			        MAX ( g_bowler_backorder[SnapshotDate] ),
			        REMOVEFILTERS ( g_bowler_backorder[SnapshotDate] ),
			        g_bowler_backorder[SnapshotDate] <= _TargetDate
			    )
			VAR _Base =
			            CALCULATE (
			                SUM ( g_bowler_backorder[SupplyRelatedBOValue2] ),
			                KEEPFILTERS ( g_bowler_backorder[SnapshotDate] = _LastSnapDate )
			            )
			
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
			
			```
		displayFolder: Dynamic Measures - Supply
		lineageTag: 15eb3b27-6bce-49cd-b54d-22c39d9ffb4f

