		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sfdc Win Rate Rolling 12M Bowler closed' = ```
			
			VAR _TodayMonthStart =
			    DATE( YEAR(TODAY()), MONTH(TODAY()), 1 )
			
			VAR _CurrentContextDate =
			    MAX( g_dimdate_analytics_ipd[Date] )
			
			-- Only allow months strictly before the current (open) month
			VAR _IsClosedMonth =
			    _CurrentContextDate < _TodayMonthStart
			
			-------------------------------------------
			-- Rolling 12M Logic
			-------------------------------------------
			VAR _StartDate =
			    _CurrentContextDate - 365
			
			VAR _Wins =
			    CALCULATE(
			        COUNTROWS( g_bowler_sfdc ),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Won",
			        g_bowler_sfdc[SnapshotDate] = MAX( g_bowler_sfdc[SnapshotDate] ),
			        g_dimdate_analytics_ipd[Date] > _StartDate,
			        g_dimdate_analytics_ipd[Date] <= _CurrentContextDate
			    )
			
			VAR _Losses =
			    CALCULATE(
			        COUNTROWS( g_bowler_sfdc ),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Lost",
			        g_bowler_sfdc[SnapshotDate] = MAX( g_bowler_sfdc[SnapshotDate] ),
			        g_dimdate_analytics_ipd[Date] > _StartDate,
			        g_dimdate_analytics_ipd[Date] <= _CurrentContextDate
			    )
			
			VAR _Total = _Wins + _Losses
			
			RETURN
			    IF(
			        _IsClosedMonth,
			        DIVIDE( _Wins, _Total ),
			        BLANK()
			    )
			
			```
		lineageTag: 06997e73-f8cd-4563-b214-f30148b7a4e1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sfdc Win Rate Competitive Bowler Closed' = ```
			
			VAR _TodayMonthStart =
			    DATE( YEAR(TODAY()), MONTH(TODAY()), 1 )
			
			VAR _CurrentContextDate =
			    MAX( g_dimdate_analytics_ipd[Date] )
			
			VAR _IsClosedMonth =
			    _CurrentContextDate < _TodayMonthStart
			
			---------------------------------------------
			-- Win / Loss calculation
			---------------------------------------------
			VAR _Wins =
			    CALCULATE(
			        COUNTROWS(g_bowler_sfdc),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Won",
			        g_bowler_sfdc[OpportunityReasonCategory] = "Competitive",
			        g_bowler_sfdc[SnapshotDate] = MAX(g_bowler_sfdc[SnapshotDate])
			    )
			
			VAR _Losses =
			    CALCULATE(
			        COUNTROWS(g_bowler_sfdc),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Lost",
			        g_bowler_sfdc[OpportunityReasonCategory] = "Competitive",
			        g_bowler_sfdc[SnapshotDate] = MAX(g_bowler_sfdc[SnapshotDate])
			    )
			
			VAR _Total = _Wins + _Losses
			
			---------------------------------------------
			RETURN
			    IF(
			        _IsClosedMonth,
			        DIVIDE(_Wins, _Total),
			        BLANK()
			    )
			
			```
		lineageTag: d94a8fbb-8475-45e3-823f-44825d9f99e4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sfdc Probable Won Bowler Future Applied' = ```
			
			VAR _TodayMonthStart =
			    DATE( YEAR(TODAY()), MONTH(TODAY()), 1 )
			
			--------------------------------------------
			-- Identify the latest fully closed month
			--------------------------------------------
			VAR _LatestClosedMonthDate =
			    CALCULATE(
			        MAX( g_dimdate_analytics_ipd[Date] ),
			        g_dimdate_analytics_ipd[Date] < _TodayMonthStart
			    )
			
			--------------------------------------------
			-- Fetch win rate from that month only (scalar)
			-- REMOVEFILTERS ensures it does NOT collapse the visual
			--------------------------------------------
			VAR _ClosedMonthWinRate =
			    CALCULATE(
			        [Sfdc Win Rate Rolling 12M],
			        g_dimdate_analytics_ipd[Date] = _LatestClosedMonthDate,
			        REMOVEFILTERS( g_dimdate_analytics_ipd )
			    )
			
			--------------------------------------------
			-- Open pipeline from current filter context
			--------------------------------------------
			VAR _OpenPipeline =
			    [Sfdc FiscalYearAmount Open Proba Adjusted]
			
			--------------------------------------------
			RETURN
			    _OpenPipeline * _ClosedMonthWinRate
			
			```
		lineageTag: c1f90f3a-9360-47b7-b2a7-52c7b4b87109

		annotation PBI_FormatHint = {"isGeneralNumber":true}

