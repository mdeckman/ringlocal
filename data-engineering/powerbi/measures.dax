	measure 'Order In Dynamic Requested FY' = ```
			
			VAR _today   = TODAY()
			VAR _fyStart = DATE( YEAR(_today) - IF( MONTH(_today) < 10, 1, 0 ), 10, 1 )
			VAR _fyEnd   = EOMONTH( _fyStart, 11 )  -- last day of September
			VAR _base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			        "Revenue",
			            SUMX (
			                FILTER (
			                    g_bowler_orders,
			                    g_bowler_orders[RequestedDeliveryDate] >= _fyStart
			                        && g_bowler_orders[RequestedDeliveryDate] <= _fyEnd
			                ),
			                COALESCE ( g_bowler_orders[OrderQuantityBase], 0 )
			                    * COALESCE ( g_bowler_orders[UnitPriceUsd], 0 )
			            ),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_orders[OrderQuantityBase] ),
			                g_bowler_orders[RequestedDeliveryDate] >= _fyStart,
			                g_bowler_orders[RequestedDeliveryDate] <= _fyEnd
			            ),
			        BLANK()
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _base, 1000 ),
			        "M",     DIVIDE ( _base, 1000000 ),
			        _base
			    )
			
			```
		displayFolder: Testing
		lineageTag: 6517b910-b4b0-4917-a4cb-a0767c33cc23

		annotation PBI_FormatHint = {"isGeneralNumber":true}

