	measure 'Forecast Accuracy Lag 2 Dynamic' = 1 - CALCULATE(DIVIDE(ABS([Demand Supply Registered Dynamic]-[Forecast Supply lag2 Dynamic]),[Demand Supply Registered Dynamic]))
		formatString: 0%;-0%;0%
		displayFolder: Dynamic Measures - Supply
		lineageTag: a8d7dca7-37f9-44de-a39b-d2664813875a

	measure 'Forecast Supply lag2 Dynamic' =
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[CalendarDate] )
			
			-- Month that is 2 months before the target date
			VAR _LagMonthStart =
			    DATE ( YEAR ( EDATE ( _TargetDate, -2 ) ), MONTH ( EDATE ( _TargetDate, -2 ) ), 1 )
			VAR _LagMonthEnd =
			    EOMONTH ( _TargetDate, -2 )
			
			-- Latest snapshot *date* within that lag month
			VAR _LastSnapDateLag2 =
			    CALCULATE (
			        MAX ( g_bowler_fcst[SnapshotDate]  ),
			        REMOVEFILTERS ( g_bowler_fcst[SnapshotDate] ),
			        DATEVALUE ( g_bowler_fcst[SnapshotDate] ) >= _LagMonthStart,
			        DATEVALUE ( g_bowler_fcst[SnapshotDate] ) <= _LagMonthEnd
			    )
			
			VAR _Base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			        "Revenue", BLANK (),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_fcst[ConsensuFinalForecast] ),
			                DATEVALUE ( g_bowler_fcst[SnapshotDate] ) = _LastSnapDateLag2
			            )
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
		formatString: #,0
		displayFolder: Dynamic Measures - Supply
		lineageTag: 35f66163-a87c-4d0e-9ce9-23776f6a66b6

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Forecast Accuracy Lag2 Bowler Dynamic' =
			
			VAR _CurrentDate = FIRSTDATE ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR _MonthEnd    = EOMONTH ( _CurrentDate, 0 )   // last day of the current month
			RETURN
			IF (
			    _MonthEnd < TODAY (),    // show only if the month is fully closed
			    1 - CALCULATE (
			        DIVIDE (
			            ABS ( [Demand Supply Registered Dynamic] - [Forecast Supply lag2 Dynamic] ),
			            [Demand Supply Registered Dynamic]
			        )
			    ),
			    BLANK ()
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Dynamic Measures - Supply
		lineageTag: 8b0d7026-d8d2-440e-a778-3c47edcfcdfb

	measure 'Fin. Actuals SPLY Dynamic' =
			
			VAR _base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			        "Revenue",
			            CALCULATE (
			                SUM ( g_bowler_finance_actuals_ipd_cy[ActRevBUDRate] ),
			                g_bowler_finance_actuals_ipd_cy[RptCurrency] = "USD",
			                g_bowler_finance_actuals_ipd_cy[GLRptCatg] = "Other Revenue",
			                SAMEPERIODLASTYEAR ( g_dimdate_analytics_ipd[CalendarDate] )
			            ),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_finance_actuals_ipd_cy[ActUnits] ),
			                g_bowler_finance_actuals_ipd_cy[RptCurrency] = "USD",
			                g_bowler_finance_actuals_ipd_cy[GLRptCatg] = "Other Revenue",
			                SAMEPERIODLASTYEAR ( g_dimdate_analytics_ipd[CalendarDate] )
			            ),
			        BLANK()   -- else/default to avoid trailing comma error
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1",     _base,
			        "/1000",  DIVIDE ( _base, 1000 ),
			        "M",      _base / 1000000,
			        _base     -- default if nothing selected
			    )
		displayFolder: Dynamic Measures - Finance
		lineageTag: a326992a-396c-4239-bf2c-da105bc223c8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Forecast Accuracy Lag2 (Last Closed Month)' =
			
			VAR _CtxMaxDate =
			    MAX ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR _LatestClosedMonth =
			    CALCULATE (
			        MAX ( g_dimdate_analytics_ipd[CalendarDate] ),
			        FILTER (
			            ALL ( g_dimdate_analytics_ipd ),
			            g_dimdate_analytics_ipd[IsClosedMonth] = TRUE ()
			                && g_dimdate_analytics_ipd[CalendarDate] <= _CtxMaxDate
			        )
			    )
			RETURN
			IF (
			    ISBLANK ( _LatestClosedMonth ),
			    BLANK (),
			    CALCULATE (
			        1 - DIVIDE (
			                ABS ( [Demand Supply Registered Dynamic] - [Forecast Supply lag2 Dynamic] ),
			                [Demand Supply Registered Dynamic]
			            ),
			        KEEPFILTERS (
			            DATESBETWEEN (
			                g_dimdate_analytics_ipd[CalendarDate],
			                STARTOFMONTH ( _LatestClosedMonth ),
			                ENDOFMONTH ( _LatestClosedMonth )
			            )
			        )
			    )
			)
		displayFolder: Dynamic Measures - Supply
		lineageTag: eb055745-4651-4eb9-9310-a6762b53ae3c

