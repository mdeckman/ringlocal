	measure 'Fin. Budget Dynamic' =
			
			VAR _base =
			
			SWITCH(
			    SELECTEDVALUE('slc_Metric'[Metric]),
			    "Revenue", CALCULATE(SUM(g_bowler_finance_budget_ipd_cy[BudgetRevenue]),g_bowler_finance_budget_ipd_cy[RPTCurrency]="USD",g_bowler_finance_budget_ipd_cy[ReAccount]="R_PL_Rev",g_bowler_finance_budget_ipd_cy[Category]="BUD_FINAL"),
			    "Units",  CALCULATE(SUM(g_bowler_finance_budget_ipd_cy[BudgetUnits]),g_bowler_finance_budget_ipd_cy[RPTCurrency]="USD",g_bowler_finance_budget_ipd_cy[ReAccount]="R_KPI_VOLUME",g_bowler_finance_budget_ipd_cy[Category]="BUD_FINAL")
			)
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1",     _base,
			        "/1000",  DIVIDE ( _base, 1000 ),
			        "M",      _base / 1000000,
			        _base     -- default if nothing selected
			    )
		formatString: #,0
		displayFolder: Dynamic Measures - Finance
		lineageTag: 6f953731-a765-4a42-81a6-93236635153a

		annotation PBI_FormatHint = {"isDecimal":true}

