			        MAX ( g_bowler_backorder[SnapshotDate] ),
			        REMOVEFILTERS ( g_bowler_backorder[SnapshotDate] ),
			        DATEVALUE ( g_bowler_backorder[SnapshotDate] ) <= _TargetDate,
			        DATEADD(g_dimdate_analytics_ipd[CalendarDate],-1,MONTH)
			    )
			VAR _Base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
