			    "Units", CALCULATE(SUM(g_bowler_finance_actuals_ipd_cy[ActUnits]),g_bowler_finance_actuals_ipd_cy[RptCurrency]="USD",g_bowler_finance_actuals_ipd_cy[GLRptCatg]="Other Revenue")
