	measure 'Order Open Dynamic' = ```
			
			VAR _filteredBase =
			    CALCULATE (
			        SWITCH (
			            SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			            "Revenue",
			                SUMX (
			                    g_bowler_orders,
			                    COALESCE ( g_bowler_orders[OpenQuantityBase], 0 )
			                        * COALESCE ( g_bowler_orders[UnitPriceUsd], 0 )
			                ),
			            "Units",
			                SUM ( g_bowler_orders[OpenQuantityBase] )
			        ),
			        KEEPFILTERS (
			            NOT ( g_bowler_orders[Orderstatuslineharmonized] IN { "CANCELLED", "NOT RELEVANT" } )
			        )
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _filteredBase, 1000 ),
			        "M",     DIVIDE ( _filteredBase, 1000000 ),
			        _filteredBase
			    )
			
			```
		formatString: #,0
		displayFolder: Dynamic Measures - Supply
		lineageTag: 209cee32-dd2d-4f9b-b8e0-ebfe912ae3c9

	measure 'Order Shipped Dynamic' = ```
			
			VAR _Base =
			    CALCULATE (
			        SWITCH (
			            SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			            "Revenue",
			                SUMX (
			                    FILTER (
			                        g_bowler_orders,
			                        NOT ISBLANK ( g_bowler_orders[ActualShipDate] )
			                    ),
			                    COALESCE ( g_bowler_orders[OrderQuantityBase], 0 )
			                        * COALESCE ( g_bowler_orders[UnitPriceUsd], 0 )
			                ),
			            "Units",
			                CALCULATE (
			                    SUM ( g_bowler_orders[OrderQuantityBase] ),
			                    NOT ISBLANK ( g_bowler_orders[ActualShipDate] )
			                )
			        ),
			        KEEPFILTERS (
			            NOT (
			                g_bowler_orders[Orderstatuslineharmonized]
			                    IN { "CANCELLED", "NOT RELEVANT" }
			            )
			        )
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1",    _Base,
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base    // Default if nothing selected
			    )
			
			```
