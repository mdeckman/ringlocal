	measure 'Order In Period (Ext)' = ```
			
			VAR _minSel = MINX(ALLSELECTED('g_dimdate_analytics_ipd'[CalendarDate]), 'g_dimdate_analytics_ipd'[CalendarDate])
			VAR _maxSel = MAXX(ALLSELECTED('g_dimdate_analytics_ipd'[CalendarDate]), 'g_dimdate_analytics_ipd'[CalendarDate])
			RETURN
			CALCULATE (
			    [Order In Dynamic (Ext)],
			    -- kill active CreateDate filter from DimDate
			    REMOVEFILTERS ( g_bowler_orders[CreateDate] ),
			    -- use RequestedDeliveryDate for the current DimDate month
			    USERELATIONSHIP ( g_bowler_orders[_nkeyRequestedDeliveryDate], 'g_dimdate_analytics_ipd'[skeyDay] ),
			    -- window constraints
			    g_bowler_orders[CreateDate] <= _maxSel,
			    g_bowler_orders[RequestedDeliveryDate] >= _minSel,
			    g_bowler_orders[RequestedDeliveryDate] <= _maxSel
			)
			
			```
		formatString: #,0
		displayFolder: Dynamic Measures - Supply
		lineageTag: 92ef9483-12a8-4ab7-a39d-81c29e3a6cd3

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Order Backlog Period (Ext)' = ```
			
			-- CreateDate < min selected; ActualShipDate within selected window
			VAR _minSel =
			    CALCULATE ( MIN ( 'g_dimdate_analytics_ipd'[CalendarDate] ),
			                ALLSELECTED ( 'g_dimdate_analytics_ipd'[CalendarDate] ) )
			VAR _maxSel =
			    CALCULATE ( MAX ( 'g_dimdate_analytics_ipd'[CalendarDate] ),
			                ALLSELECTED ( 'g_dimdate_analytics_ipd'[CalendarDate] ) )
			VAR _value =
			    CALCULATE (
			        [Order In Dynamic (Ext)],
			        REMOVEFILTERS ( g_bowler_orders[ActualShipDate], g_bowler_orders[CreateDate] ),
			        KEEPFILTERS ( g_bowler_orders[CreateDate] < _minSel ),
			        KEEPFILTERS ( g_bowler_orders[ActualShipDate] >= _minSel
			                   && g_bowler_orders[ActualShipDate] <= _maxSel )
			    )
			RETURN
			    IF ( ISBLANK ( _value ) || _value = 0, "No BackLog", _value )
			
			```
		displayFolder: Dynamic Measures - Supply
		lineageTag: 8f8f03ba-b599-4646-a4d6-cd5731b81047

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Order In Future Period (Ext)' = ```
			
			-- CreateDate ≤ max selected; RequestedDeliveryDate > max selected
			
			VAR _minSel =
			    CALCULATE ( MIN ( 'g_dimdate_analytics_ipd'[CalendarDate] ), ALLSELECTED ( 'g_dimdate_analytics_ipd'[CalendarDate] ) )
			VAR _maxSel =
			    CALCULATE ( MAX ( 'g_dimdate_analytics_ipd'[CalendarDate] ), ALLSELECTED ( 'g_dimdate_analytics_ipd'[CalendarDate] ) )
			RETURN
			CALCULATE (
			    [Order In Dynamic (Ext)],
			    REMOVEFILTERS ( g_bowler_orders[RequestedDeliveryDate], g_bowler_orders[CreateDate] ),
			    KEEPFILTERS ( g_bowler_orders[CreateDate] <= _maxSel ),
			    KEEPFILTERS ( g_bowler_orders[RequestedDeliveryDate] > _maxSel )
			)
			
			```
		displayFolder: Dynamic Measures - Supply
		lineageTag: 05961812-8b78-45c9-bc43-4c5f628b3943

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Diff Order to Budget %' = ```
			
			VAR _order  = [Order In Period (Ext)]
			VAR _budget = [Fin. Budget Dynamic]
			RETURN
			    DIVIDE( _order - _budget, _budget )
			
			```
		formatString: 0.00%;-0.00%;0.00%
