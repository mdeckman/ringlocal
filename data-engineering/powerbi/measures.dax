	measure 'Fin. Growth Units Bowler' = ```
			
			VAR _currDate =
			    MAX ( g_dimdate_analytics_ipd[Date] )   // use your date column
			VAR _curr =
			    [Fin. Units Actuals]
			VAR _prev =
			    [Fin. Units Actuals SPLY]
			RETURN
			IF (
			    _currDate > TODAY(),       // if date in context is in the future
			    BLANK(),
			    DIVIDE ( _curr, _prev, 0 ) - 1
			)
			
			```
		displayFolder: Dynamic Measures - Finance
		lineageTag: 78a5f150-1f09-43f7-b25a-7a66d58db186

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Safety Stock Dynamic' = ```
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[CalendarDate] )    -- latest day in current selection
			VAR _LastSnapDate =
			    CALCULATE (
			        MAX ( g_bowler_inventory[SnapshotDate] ),     -- latest snapshot ≤ target date
			        REMOVEFILTERS ( g_bowler_inventory[SnapshotDate] ),
			        g_bowler_inventory[SnapshotDate] <= _TargetDate
			    )
			VAR _Base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			        "Revenue",
			            CALCULATE (
			                SUM ( g_bowler_inventory[SafetyStockDays] ),
			                g_bowler_inventory[SnapshotDate] = _LastSnapDate
			            ),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_inventory[SafetyStockDays] ),
			                g_bowler_inventory[SnapshotDate] = _LastSnapDate
			            )
			    )
			RETURN
