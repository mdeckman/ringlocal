	measure 'Inventory Unrestricted Dynamic LM' = ```
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[CalendarDate] )    -- latest day in current selection
			VAR _LastSnapDate =
			    CALCULATE (
			        MAX ( g_bowler_inventory[SnapshotDate] ),     -- latest snapshot ≤ target date
			        REMOVEFILTERS ( g_bowler_inventory[SnapshotDate] ),
			        g_bowler_inventory[SnapshotDate] <= _TargetDate,
			        DATEADD(g_dimdate_analytics_ipd[DateKeySPLY],-1,MONTH)
			    )
			VAR _Base =
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Metric'[Metric] ),
			        "Revenue",
			            CALCULATE (
			                SUM ( g_bowler_inventory[UnRestrictedValue] ),
			                g_bowler_inventory[SnapshotDate] = _LastSnapDate
			            ),
			        "Units",
			            CALCULATE (
			                SUM ( g_bowler_inventory[UnRestrictedQty] ),
			                g_bowler_inventory[SnapshotDate] = _LastSnapDate
			            )
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
			
			```
		displayFolder: Dynamic Measures - Supply
		lineageTag: e795b392-5d77-4381-b7d6-ebe1e2a8b3f3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

