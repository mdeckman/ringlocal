		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Complaints >90 Days Dynamic' = ```
			
			VAR _asOf =
			    EOMONTH ( MAX ( 'g_dimdate_analytics_ipd'[Date] ), 0 )   -- or just MAX(...) if you don't want month-end
			VAR _base =
			    CALCULATE (
			        DISTINCTCOUNT ( g_bowler_complaints[PrId] ),
			        -- ignore Date table so page/month slicers don't filter the age test
			        REMOVEFILTERS ( 'g_dimdate_analytics_ipd' ),
			
			        -- only open
			        KEEPFILTERS ( VALUE ( g_bowler_complaints[PrIsClosed] ) = 0 ),
			
			        -- valid awareness date
			        KEEPFILTERS ( NOT ISBLANK ( g_bowler_complaints[AwarenessDate] ) ),
			
			        -- age > 90 days
			        KEEPFILTERS ( DATEDIFF ( g_bowler_complaints[AwarenessDate], _asOf, DAY ) > 90 ),
			
			        -- exclude "concomitant" (case-insensitive) and incorrect entries
			        KEEPFILTERS ( NOT CONTAINSSTRING ( LOWER ( g_bowler_complaints[SuspectOrConcomitant] ), "concomitant" ) ),
			        KEEPFILTERS ( g_bowler_complaints[AsReportedCode1] <> "Incorrect Entry" )
			    )
			RETURN
			SWITCH (
			    SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			    "/1",     _base,
			    "/1000",  DIVIDE ( _base, 1000 ),
			    "M",      _base / 1000000,
			    _base
			)
			
			```
		displayFolder: Dynamic Measures - Quality
		lineageTag: 871ec03f-7c24-440c-b7dd-c77fe0d6a458

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Complaints >90 Days Bowler Dynamic' =
			
			VAR _colEnd   = EOMONTH( MAX ( 'g_dimdate_analytics_ipd'[DateKeySPLY] ), 0 )   -- as-of the month on the column
			VAR _cutoff   = _colEnd - 90
			VAR _base =
			    CALCULATE (
			        DISTINCTCOUNT ( g_bowler_complaints[PrId] ),
			        REMOVEFILTERS ( 'g_dimdate_analytics_ipd' ),                    -- include full history, not just the column month
			        KEEPFILTERS ( g_bowler_complaints[PrIsClosed] = "0" ),
			        KEEPFILTERS ( NOT ISBLANK ( g_bowler_complaints[AwarenessDate] ) ),
			        KEEPFILTERS ( g_bowler_complaints[AwarenessDate] <= _cutoff )  -- “older than 90 days” as of that month
			    )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1",     _base,
			        "/1000",  DIVIDE ( _base, 1000 ),
			        "M",      _base / 1000000,
			        _base     -- default if nothing selected
			    )
		formatString: 0
		displayFolder: Dynamic Measures - Quality
		lineageTag: c7546d0d-3d4e-487d-8427-e8b520d89389

	measure 'Complaints per Million > 90 Dynamic' = ```
			
			VAR _num = [Complaints >90 Days Dynamic]
			VAR _den = [Fin. Units Actuals]
			VAR _val = 1000000 * DIVIDE(_num, _den)
			RETURN
			    IF(
			        OR(ISBLANK(_val), _val = 0),
			        0,
			        _val
			    )
			
			```
		formatString: #,0.00
		displayFolder: Dynamic Measures - Quality
		lineageTag: 1c298725-d393-44cb-916d-5df0078af0ac

	measure 'Complaints per Million Dynamic SPLY' = ```
			
			VAR _num = [Complaints Dynamic SPLY]
			VAR _den = [Fin. Actuals R12M SPLY Dynamic] 
			RETURN 1000000 * DIVIDE ( _num, _den )
			
			```
		displayFolder: Dynamic Measures - Quality
		lineageTag: 1f1d9999-39c3-4496-a668-5d7be1ccfb1f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Complaints per Million YoY Growth %' = ```
			
			VAR ThisPeriod = [Complaints per Million Dynamic]
			VAR LastYear = [Complaints per Million Dynamic SPLY]
			RETURN
			IF(
			    NOT ISBLANK(LastYear),
			    DIVIDE(ThisPeriod - LastYear, LastYear),
			    BLANK()
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
