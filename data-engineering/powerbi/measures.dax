	measure 'Sfdc New Revenue Added' = ```
			
			VAR _base =
			    CALCULATE(
			        SUM( g_bowler_sfdc[FiscalYearAmountUSD] ),
			        
			        -- Only opportunities created in the selected period
			        g_bowler_sfdc[OpportunityCreatedDate] >= MIN(g_dimdate_analytics_ipd[Date]) &&
			        g_bowler_sfdc[OpportunityCreatedDate] <= MAX(g_dimdate_analytics_ipd[Date]),
			
			        -- Always use latest SFDC snapshot
			        g_bowler_sfdc[SnapshotDate] = MAX(g_bowler_sfdc[SnapshotDate])
			    )
			RETURN
			    SWITCH(
			        SELECTEDVALUE('slc_Scale'[Scale]),
			        "/1",     _base,
			        "/1000",  DIVIDE(_base, 1000),
			        "M",      _base / 1000000,
			        _base
