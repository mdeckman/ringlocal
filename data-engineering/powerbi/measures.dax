	measure 'Working Days % Elapsed vs LY' =
			
			DIVIDE ( [Working Days (Selected, Elapsed)], [Working Days (Selected, Elapsed) SPLY] )-1
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Helpers
		lineageTag: f9138fda-457f-4038-83ea-7a5d5864643e

	measure 'Working Days (Selected, Elapsed) SPLY' = ```
			
			CALCULATE(
			    VAR _cutoff_sply =
			        MIN(
			            EDATE(TODAY(), -12),                           -- "today" in last year's timeline
			            MAX(g_dimdate_analytics_ipd[Date])             -- max date within the SPLY period
			        )
			    RETURN
			        COUNTROWS(
			            FILTER(
			                VALUES(g_dimdate_analytics_ipd[Date]),
			                g_dimdate_analytics_ipd[Date] <= _cutoff_sply
			                    && WEEKDAY(g_dimdate_analytics_ipd[Date], 2) <= 5
			                    -- && g_dimdate_analytics_ipd[IsHoliday] = FALSE()   -- optional holiday exclusion
			            )
			        ),
			    SAMEPERIODLASTYEAR(g_dimdate_analytics_ipd[DateKeySPLY])       -- shift selection to SPLY
			)
			
			```
		displayFolder: Helpers
		lineageTag: 7450ad37-83db-4ce1-a5c2-7a0bda8b93e6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Working Days (Selected, Total) SPLY' = ```
			
			CALCULATE(
			    COUNTROWS(
			        FILTER(
			            VALUES(g_dimdate_analytics_ipd[Date]),
			            WEEKDAY(g_dimdate_analytics_ipd[Date], 2) <= 5
			            -- && g_dimdate_analytics_ipd[IsHoliday] = FALSE()   -- optional
			        )
			    ),
			    SAMEPERIODLASTYEAR(g_dimdate_analytics_ipd[DateKeySPLY])
			)
			
			```
		displayFolder: Helpers
		lineageTag: 03375c41-a151-4c64-947b-d97adeaa7dbb

