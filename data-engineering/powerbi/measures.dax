	measure 'SIOP Absolute Variance' =
			
			VAR _Today   = TODAY()
			VAR _FYStart = DATE( YEAR(_Today) - IF( MONTH(_Today) < 10, 1, 0 ), 10, 1 )   // Oct 1 of current FY
			VAR _FYEnd   = EOMONTH( _FYStart, 11 )                                        // Sep 30 of current FY
			RETURN
			CALCULATE([Forecast Supply Dynamic test]-[Fin. Projection Scenario Dynamic],
			    REMOVEFILTERS( 'g_dimdate_analytics_ipd'[CalendarDate] ),
			    KEEPFILTERS(
			        'g_dimdate_analytics_ipd'[Date] >= _FYStart &&
			        'g_dimdate_analytics_ipd'[Date] <= _FYEnd
			    ))
		formatString: #,0
		displayFolder: Performance Measures
		lineageTag: aeea9d17-c5d1-4056-8c29-62e8862871db

