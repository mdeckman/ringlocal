		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Complaints >60 Days' = ```
			
			CALCULATE(
			    COUNTROWS('g_bowler_complaints'),
			    FILTER(
			        'g_bowler_complaints',
			        
			        -- Compute aging per row
			        VAR _Aging =
			            IF(
			                ISBLANK('g_bowler_complaints'[OrigDateClosed]),
			                -- Open complaint → use Today
			                DATEDIFF(
			                    'g_bowler_complaints'[AwarenessDate],
			                    TODAY(),
			                    DAY
			                ),
			                -- Closed complaint → use closure date
			                DATEDIFF(
			                    'g_bowler_complaints'[AwarenessDate],
			                    'g_bowler_complaints'[OrigDateClosed],
			                    DAY
			                )
			            )
			        RETURN
			            _Aging > 60 &&
			            -- Ensure we never show future periods in Bowler
			            'g_bowler_complaints'[AwarenessDate] <= TODAY()
			    )
			)
			
			```
		displayFolder: Dynamic Measures - Quality
		lineageTag: b29f540d-9da9-4920-8e0a-2e590eab2940

