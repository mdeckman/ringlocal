	measure 'Sfdc Win Rate' = ```
			
			VAR _Wins =
			    CALCULATE(
			        COUNTROWS( g_bowler_sfdc ),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Won",
			        g_bowler_sfdc[SnapshotDate] = MAX( g_bowler_sfdc[SnapshotDate] )
			    )
			
			VAR _Losses =
			    CALCULATE(
			        COUNTROWS( g_bowler_sfdc ),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Lost",
			        g_bowler_sfdc[SnapshotDate] = MAX( g_bowler_sfdc[SnapshotDate] )
			    )
			
			VAR _Total =
			    _Wins + _Losses
			
			RETURN
			    DIVIDE( _Wins, _Total )
			
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Dynamic Measures - SFDC
		lineageTag: 2b9023a1-c70e-4a85-bba6-56b6c6aa28fb

	measure 'Sfdc Win Rate Rolling 12M' =
			
			VAR _StartDate =
			    MAX( g_dimdate_analytics_ipd[Date] ) - 365
			
			VAR _Wins =
			    CALCULATE(
			        COUNTROWS( g_bowler_sfdc ),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Won",
			        g_bowler_sfdc[SnapshotDate] = MAX( g_bowler_sfdc[SnapshotDate] ),
			        g_dimdate_analytics_ipd[Date] > _StartDate,
			        g_dimdate_analytics_ipd[Date] <= MAX( g_dimdate_analytics_ipd[Date] )
			    )
			
			VAR _Losses =
			    CALCULATE(
			        COUNTROWS( g_bowler_sfdc ),
			        g_bowler_sfdc[OpportunityStageDerived] = "Closed Lost",
			        g_bowler_sfdc[SnapshotDate] = MAX( g_bowler_sfdc[SnapshotDate] ),
			        g_dimdate_analytics_ipd[Date] > _StartDate,
			        g_dimdate_analytics_ipd[Date] <= MAX( g_dimdate_analytics_ipd[Date] )
			    )
			
			VAR _Total =
			    _Wins + _Losses
			
			RETURN
			    DIVIDE( _Wins, _Total )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Dynamic Measures - SFDC
		lineageTag: 0f86a4ab-ae95-408f-b075-4a7733ecd6b9

