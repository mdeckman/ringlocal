	measure 'Demand Supply Registered Units' = ```
			
			VAR _LastSnapDate =
			    CALCULATE (
			        MAX ( g_bowler_demand[SnapshotDate]),
			        REMOVEFILTERS ( g_bowler_demand[SnapshotDate])
			    )
			VAR _Base =
			            CALCULATE (
			                SUM ( g_bowler_demand[DmdQtytot] ),
			                 g_bowler_demand[SnapshotDate] = _LastSnapDate
			            )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
			
			```
		displayFolder: Dynamic Measures - Supply
		lineageTag: 11c75675-37d3-4aae-b68e-93cf56d28306

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Forecast Supply lag2 Units' =
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[CalendarDate] )
			
			-- Month that is 2 months before the target date
			VAR _LagMonthStart =
			    DATE ( YEAR ( EDATE ( _TargetDate, -2 ) ), MONTH ( EDATE ( _TargetDate, -2 ) ), 1 )
			VAR _LagMonthEnd =
			    EOMONTH ( _TargetDate, -2 )
			
			-- Latest snapshot *date* within that lag month
			VAR _LastSnapDateLag2 =
			    CALCULATE (
			        MAX ( g_bowler_fcst[SnapshotDate]  ),
			        REMOVEFILTERS ( g_bowler_fcst[SnapshotDate] ),
			        DATEVALUE ( g_bowler_fcst[SnapshotDate] ) >= _LagMonthStart,
			        DATEVALUE ( g_bowler_fcst[SnapshotDate] ) <= _LagMonthEnd
			    )
			
			VAR _Base =
			            CALCULATE (
			                SUM ( g_bowler_fcst[ConsensuFinalForecast] ),
			                DATEVALUE ( g_bowler_fcst[SnapshotDate] ) = _LastSnapDateLag2
			            )
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
		displayFolder: Dynamic Measures - Supply
		lineageTag: 8ccffca3-b25f-43bf-918a-4e7ceb3c468f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Forecast Accuracy Lag2 Bowler Units' =
			
			VAR _CurrentDate = FIRSTDATE ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR _MonthEnd    = EOMONTH ( _CurrentDate, 0 )   // last day of the current month
			RETURN
			IF (
			    _MonthEnd < TODAY (),    // show only if the month is fully closed
			    1 - CALCULATE (
			        DIVIDE (
			            ABS ( [Demand Supply Registered Units] - [Forecast Supply lag2 Units] ),
			            [Demand Supply Registered Units]
			        )
			    ),
			    BLANK ()
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Dynamic Measures - Supply
		lineageTag: 8b92239c-077b-4fff-8d18-4d7eb03061e6

	measure 'Forecast Supply Dynamic test' =
			
			VAR _Metric = SELECTEDVALUE ( 'slc_Metric'[Metric] )
			VAR _Scale  = SELECTEDVALUE ( 'slc_Scale'[Scale] )
			
			-- Helper: compute the Units value for the current context *month*
			VAR __Units_PerMonth =
			    VAR _TargetDate =
			        MAX ( g_dimdate_analytics_ipd[DateKeySPLY] )  -- assumed to be a date (no time)
			    VAR _MonthStart = DATE ( YEAR ( _TargetDate ), MONTH ( _TargetDate ), 1 )
			    VAR _MonthEnd   = EOMONTH ( _TargetDate, 0 )
			
			    -- Last snapshot on/before the month end (adjust if you need strictly within month)
			    VAR _LastSnapDate_Month =
			        CALCULATE (
			            MAX ( g_bowler_fcst[SnapshotDate] ),
			            REMOVEFILTERS ( g_bowler_fcst[SnapshotDate] ),
			            g_bowler_fcst[SnapshotDate] <= _MonthEnd
			        )
			    RETURN
			        CALCULATE (
			            SUM ( g_bowler_fcst[ConsensuFinalForecast] ),
			            KEEPFILTERS ( g_bowler_fcst[SnapshotDate] = _LastSnapDate_Month )
			        )
			
			-- Helper: iterate visible months for totals
			VAR __Units_Total =
			    VAR _MonthsVisible =
			        -- Use the exact column that defines your month grain in the visual.
			        -- If you use a MonthStart or Year-Month column, prefer that here.
			        VALUES ( g_dimdate_analytics_ipd[DateKeySPLY] )
			    RETURN
			        SUMX (
			            _MonthsVisible,
			            VAR _ThisDate = g_dimdate_analytics_ipd[DateKeySPLY]
			            VAR _MonthEnd = EOMONTH ( _ThisDate, 0 )
			            VAR _LastSnapDate_Month =
			                CALCULATE (
			                    MAX ( g_bowler_fcst[SnapshotDate] ),
			                    REMOVEFILTERS ( g_bowler_fcst[SnapshotDate] ),
			                    g_bowler_fcst[SnapshotDate] <= _MonthEnd
			                )
			            RETURN
			                CALCULATE (
			                    SUM ( g_bowler_fcst[ConsensuFinalForecast] ),
			                    KEEPFILTERS ( g_bowler_fcst[SnapshotDate] = _LastSnapDate_Month ),
			                    KEEPFILTERS ( g_dimdate_analytics_ipd[DateKeySPLY] = _ThisDate )
			                )
			        )
			
			VAR _Base_Units =
			    -- If we're in a month row (the month column is in scope), compute per-month.
			    -- Otherwise (totals/subtotals), iterate months.
			    IF (
			        ISINSCOPE ( g_dimdate_analytics_ipd[DateKeySPLY] ),
			        __Units_PerMonth,
			        __Units_Total
			    )
			
			VAR _Base =
			    SWITCH (
			        _Metric,
			        "Revenue", BLANK(),
			        "Units",   _Base_Units,
			        BLANK()
			    )
			
			RETURN
			    SWITCH (
			        _Scale,
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
		formatString: #,0
		displayFolder: Dynamic Measures - Supply
		lineageTag: e2830740-d803-4c57-b5c0-f01f84ba83a8

