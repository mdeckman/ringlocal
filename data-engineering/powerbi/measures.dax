	measure 'Fin. Projection Scenario Dynamic with default' = ```
			
			VAR _selScenario = SELECTEDVALUE ( 'slc_Scenario'[Scenario] )
			VAR _m           = MONTH ( TODAY() )
			RETURN
			SWITCH (
			    TRUE (),
			
			    -- If a scenario is selected, use it
			    NOT ISBLANK ( _selScenario ),
			        CALCULATE (
			            [Fin. Projection Dynamic],
			            KEEPFILTERS ( g_bowler_finance_projections_ipd_cy[Scenario] = _selScenario )
			        ),
			
			    -- Default logic when nothing is selected
			    _m IN { 10, 11 },   -- Oct–Nov → Budget
			        [Fin. Budget Dynamic],
			
			    _m >= 6 && _m <= 9, -- Jun–Sep → PRJ3
			        CALCULATE (
			            [Fin. Projection Dynamic],
			            KEEPFILTERS ( g_bowler_finance_projections_ipd_cy[Scenario] = "PRJ3" )
			        ),
			
			    _m >= 3 && _m <= 5, -- Mar–May → PRJ2
			        CALCULATE (
			            [Fin. Projection Dynamic],
			            KEEPFILTERS ( g_bowler_finance_projections_ipd_cy[Scenario] = "PRJ2" )
			        ),
			
			    _m = 12 || _m <= 2, -- Dec–Feb → PRJ1
			        CALCULATE (
			            [Fin. Projection Dynamic],
			            KEEPFILTERS ( g_bowler_finance_projections_ipd_cy[Scenario] = "PRJ1" )
			        ),
			
			    BLANK()
			)
			
			```
		formatString: #,0
		displayFolder: Dynamic Measures - Finance
		lineageTag: 9c2e8dca-7110-46ff-a2ff-43fbf2489a99

		annotation PBI_FormatHint = {"isDecimal":true}

