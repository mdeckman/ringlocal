	measure 'Days in Selected Period' =
			
			VAR _selStart = MIN ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR _selEnd   = MAX ( g_dimdate_analytics_ipd[CalendarDate] )
			RETURN
			IF (
			    ISBLANK(_selStart) || ISBLANK(_selEnd) || _selStart > _selEnd,
			    0,
			    DATEDIFF ( _selStart, _selEnd, DAY ) + 1
			)
		formatString: 0
		displayFolder: Helpers
		lineageTag: 634b7099-867f-4172-982d-e9c9e7e8c304

	measure 'Working Days in Selected Period' =
			
			COUNTROWS (
			    FILTER (
			        VALUES ( g_dimdate_analytics_ipd[CalendarDate].[Date]),
			        WEEKDAY ( g_dimdate_analytics_ipd[CalendarDate].[Date], 2 ) <= 5
			    )
			)
		formatString: 0
		displayFolder: Helpers
		lineageTag: 13ff24a9-e0b6-4b3d-bf57-e311c0122430

	measure 'Days Elapsed (to Today) in Selection' =
			
			VAR _selStart = MIN ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR _selEnd   = MAX ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR _effEnd   = MIN ( TODAY(), _selEnd )
			RETURN
			IF (
			    ISBLANK(_selStart) || ISBLANK(_effEnd) || _selStart > _effEnd,
			    0,
			    COUNTROWS (
			        FILTER (
			            VALUES ( g_dimdate_analytics_ipd[CalendarDate] ),
			            g_dimdate_analytics_ipd[CalendarDate] >= _selStart &&
			            g_dimdate_analytics_ipd[CalendarDate] <= _effEnd &&
			            WEEKDAY ( g_dimdate_analytics_ipd[CalendarDate], 2 ) <= 5
			        )
			    )
			)
		formatString: 0
		displayFolder: Helpers
		lineageTag: 01a59c7a-07ef-4da3-a4be-ad5835b497b6

	measure 'Run-Rate Forecast (Linear, Selection)' =
			
			VAR _elapsed = [Working Days (Selected, Elapsed)]
			VAR _total   = [Working Days (Selected, Total)]
			VAR _orders  = [Order In Period (Ext)]
			RETURN
			IF(
			    ISBLANK(_orders) || _elapsed = 0 || _total = 0,
			    BLANK(),
			    DIVIDE( _orders, _elapsed ) * _total
			)
		formatString: #,0
		displayFolder: Health Metrics
		lineageTag: d3891f04-32b3-4f5c-b654-2901566fe5b0

