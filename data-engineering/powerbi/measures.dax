		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Forecast Accuracy Lag2 (Last Closed Month)2' =
			
			VAR _LastClosedDate =
			    CALCULATE (
			        MAX ( g_dimdate_analytics_ipd[CalendarDate] ),
			        FILTER (
			            ALLSELECTED ( g_dimdate_analytics_ipd[CalendarDate] ),
			            EOMONTH ( g_dimdate_analytics_ipd[CalendarDate], 0 ) < TODAY ()
			        )
			    )
			VAR _MonthStart = EOMONTH ( _LastClosedDate, -1 ) + 1
			VAR _MonthEnd   = EOMONTH ( _LastClosedDate, 0 )
			RETURN
			IF (
			    ISBLANK ( _LastClosedDate ),
			    BLANK (),
			    CALCULATE (
			        1 -
			            DIVIDE (
			                ABS ( [Demand Supply Registered Dynamic] - [Forecast Supply lag2 Dynamic] ),
			                [Demand Supply Registered Dynamic]
			            ),
			        DATESBETWEEN (
			            g_dimdate_analytics_ipd[CalendarDate],
			            _MonthStart,
			            _MonthEnd
			        )
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Dynamic Measures - Supply
		lineageTag: 20defc07-63f8-4f0b-94c3-44aef9140924

	measure 'Fmt Icon – Δ vs Target' = ```
			
			VAR _isDelta   = SELECTEDVALUE('cg_MeasuresType'[Measure Type]) = "Δ vs Target"
			VAR _metricKey = SELECTEDVALUE(_DimMetrics[MetricKey])
			VAR _delta     = [Metric Δ vs Target]
			VAR _absDiff   = ABS(_delta)
			
			-- Direction groups (same as your Bkg measure)
			VAR _positivePerfMetrics =
			{
			    "SUP_DEMAND_TOT","SUP_DEMAND_STOCK",   // Demand & stocking
			    "INV_DIOH","INV_AMT",                  // Inventory / DIOH
			    "PRC_GP_IMP",                          // Marketing – GP improvement
			    "FIN_REV","FIN_UNITS","FIN_ASP","FIN_GP","FIN_GROWR","FIN_GROWU",  // Finance
			    "SUP_OTIF",                            // service level
			    "FC_ACC",                              // forecast accuracy
			    "COMEX_WON","COMEX_SIZE",              // Commercial
			    "SPEC_PHASEAL","SPEC_IVA",             // Marketing conversions
			    "SUP_ORD_IN","SUP_ORD_SHIP","SUP_ORD_DELIV"  // Supply flow
			}
			
			VAR _negativePerfMetrics =
			{
			    "SUP_ORD_OPEN",                        // Open orders
			    "SUP_BO_SUP","SUP_BO_DIST",            // Backorders
			    "QLT_C_VOL","QLT_C_OVER90","QLT_C_NUM",// Quality
			    "PE_DELAY","PE_COMP",                  // Sustaining
			    "COMEX_LOST"                           // Commercial lost
			}
			
			VAR _variancePerfMetrics =
			{
			    "FC_SIOP", "FC_EC", "FC_DIST", "PROD_PPA"
			}
			
			VAR _varianceThreshold = 0.05   // ±5%
			
			RETURN
			IF (
			    NOT _isDelta || ISBLANK(_delta) || ISBLANK(_metricKey),
			    BLANK(),
			    SWITCH (
			        TRUE(),
			        -- Variance: neutral if within band; else show direction
			        _metricKey IN _variancePerfMetrics && _absDiff <= _varianceThreshold, "◆",
			        _metricKey IN _variancePerfMetrics && _absDiff >  _varianceThreshold, IF(_delta >= 0, "▲", "▼"),
			
			        -- Higher = better
			        _metricKey IN _positivePerfMetrics && _delta >  0, "▲",
			        _metricKey IN _positivePerfMetrics && _delta <= 0, "▼",
			
			        -- Lower = better
			        _metricKey IN _negativePerfMetrics && _delta <  0, "▲",
			        _metricKey IN _negativePerfMetrics && _delta >= 0, "▼",
			
			        BLANK()
			    )
			)
			
			```
		displayFolder: Formatting
		lineageTag: 17ca3e98-d630-42d3-be9e-1119c38597e7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'BO Dist Revenue' = ```
			
			VAR _TargetDate =
			    MAX ( g_dimdate_analytics_ipd[DateKeySPLY] )
			VAR _LastSnapDate =
			    CALCULATE (
			        MAX ( g_bowler_backorder[SnapshotDate] ),
			        REMOVEFILTERS ( g_bowler_backorder[SnapshotDate] ),
			        g_bowler_backorder[SnapshotDate] <= _TargetDate
			    )
			VAR _Base =
			            CALCULATE (
			                SUM ( g_bowler_backorder[DistroBOValue2] ),
			                KEEPFILTERS ( g_bowler_backorder[SnapshotDate] = _LastSnapDate )
			            )
			
			RETURN
			    SWITCH (
			        SELECTEDVALUE ( 'slc_Scale'[Scale] ),
			        "/1000", DIVIDE ( _Base, 1000 ),
			        "M",     DIVIDE ( _Base, 1000000 ),
			        _Base
			    )
			
			```
