	measure 'Selected Period (Min–Max FY)' = ```
			
			VAR MinD =
			    MIN ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR MaxD =
			    MAX ( g_dimdate_analytics_ipd[CalendarDate] )
			VAR MinFYNum =
			    YEAR ( MinD ) + IF ( MONTH ( MinD ) >= 10, 1, 0 )        -- Oct–Sep fiscal year
			VAR MaxFYNum =
			    YEAR ( MaxD ) + IF ( MONTH ( MaxD ) >= 10, 1, 0 )
			VAR MinFY2 =
			    RIGHT ( FORMAT ( MinFYNum, "0000" ), 2 )                  -- "26" from 2026
			VAR MaxFY2 =
			    RIGHT ( FORMAT ( MaxFYNum, "0000" ), 2 )
			VAR MinLabel =
			    FORMAT ( MinD, "mmm" ) & " FY" & MinFY2                   -- e.g., "Oct FY26"
			VAR MaxLabel =
			    FORMAT ( MaxD, "mmm" ) & " FY" & MaxFY2
			RETURN
			IF (
			    ISBLANK ( MinD ) || ISBLANK ( MaxD ),
			    BLANK (),
			    IF ( MinD = MaxD, MinLabel, MinLabel & " - " & MaxLabel )
			)
			
			```
		displayFolder: Titles
		lineageTag: 1a69619a-f409-4d6d-943c-7358fe13cef5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Perf. BO Rev vs. Target' = DIVIDE([BO Supply Revenue] - [Current Month - Target Supply Back Order], [Current Month - Target Supply Back Order])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Performance Measures
		lineageTag: 6038ac5a-cf89-4d7c-9a95-f0ff7c23c546

	measure 'Fmt Bkg – Δ vs Target' = ```
			
			VAR _isDelta   = SELECTEDVALUE('cg_MeasuresType'[Measure Type]) = "Δ vs Target"
			VAR _metricKey = SELECTEDVALUE(_DimMetrics[MetricKey])
			VAR _func      = SELECTEDVALUE(_DimMetrics[Function])
			VAR _delta     = [Metric Δ vs Target]                  // % diff vs target, e.g., +0.08 = +8%
			VAR _absDiff   = ABS(_delta)
			
			-- Direction groups
			VAR _positivePerfMetrics =
			   {
			        "SUP_DEMAND_TOT","SUP_DEMAND_STOCK",   // Demand & stocking
			            "INV_DIOH","INV_AMT",                  // Inventory / DIOH
			    "PRC_GP_IMP",          // Marketing – GP improvement
			    "FIN_REV","FIN_UNITS","FIN_ASP","FIN_GP","FIN_GROWR","FIN_GROWU",  // Finance
			    "SUP_OTIF",            // Supply – service level (exception: higher is better)
			    "FC_ACC",              // Supply/Fcst – accuracy (higher is better)
			    "COMEX_WON","COMEX_SIZE", // Commercial – won & funnel size
			    "SPEC_PHASEAL","SPEC_IVA", // Marketing specifics – conversions (assumed higher is better)
			    // Marketing forecasts (assumed higher vs target is better)
			    "SUP_ORD_IN","SUP_ORD_SHIP","SUP_ORD_DELIV" // Supply flow (assumed higher vs target is better)
			}  // higher = better
			
			VAR _negativePerfMetrics =
			   {
			
			    "SUP_ORD_OPEN",                        // Open orders
			    "SUP_BO_SUP","SUP_BO_DIST", "SUP_BO_SUPREV",           // Backorders
			
			    "QLT_C_VOL","QLT_C_OVER90","QLT_C_NUM","QLT_C_TAT",// Quality – lower is better
			    "PE_DELAY","PE_COMP",                  // Sustaining – delays/under-resourced
			    "COMEX_LOST"                           // Commercial – lost customers
			}
			
			-- Variance group: closer to target (± threshold) = GREEN; outside = RED
			VAR _variancePerfMetrics =
			{
			    "FC_SIOP",     // SIOP – treat as closeness to plan (adjust if you prefer direction)
			    "FC_EC","FC_DIST", "FC_SKU",
			    "PROD_PPA"     // PPA – purchase price vs target (often “as close as possible”)
			}
			
			VAR _varianceThreshold = 0.05   // 5% band for variance metrics
			
			RETURN
			IF(
			    NOT _isDelta || ISBLANK(_delta),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        -- Variance-based: green if within band, else red
			        _metricKey IN _variancePerfMetrics && _absDiff <= _varianceThreshold, "#BEDC96",  -- light green
			        _metricKey IN _variancePerfMetrics && _absDiff >  _varianceThreshold, "#F0A0A0",  -- light red
			
			        -- Positive performance: higher is better
			        _metricKey IN _positivePerfMetrics && _delta >  0, "#BEDC96",
			        _metricKey IN _positivePerfMetrics && _delta <= 0, "#F0A0A0",
			
			        -- Negative performance: lower is better
			        _metricKey IN _negativePerfMetrics && _delta <  0, "#BEDC96",
			        _metricKey IN _negativePerfMetrics && _delta >= 0, "#F0A0A0",
			
			        BLANK()
			    )
			)
			
			```
		displayFolder: Formatting
		lineageTag: 74ca360e-2cfa-421e-aaba-eb8acdd470d0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Fmt Font – Δ vs Target' = ```
			
			VAR _isDelta   = SELECTEDVALUE('cg_MeasuresType'[Measure Type]) = "Δ vs Target"
			VAR _metricKey = SELECTEDVALUE(_DimMetrics[MetricKey])
			VAR _func      = SELECTEDVALUE(_DimMetrics[Function])
			VAR _delta     = [Metric Δ vs Target]
			VAR _absDiff   = ABS(_delta)
			
			-- Direction groups
			VAR _positivePerfMetrics =
			   {
			    "PRC_GP_IMP",          // Marketing – GP improvement
			        "FIN_ASP",     // ASP – closer to target preferred
			        "INV_DIOH","INV_AMT",                  // Inventory / DIOH
			        "SUP_DEMAND_TOT","SUP_DEMAND_STOCK",   // Demand & stocking
			    "FIN_REV","FIN_UNITS","FIN_GP","FIN_GROWR","FIN_GROWU",  // Finance
			    "SUP_OTIF",            // Supply – service level (exception: higher is better)
			    "FC_ACC",              // Supply/Fcst – accuracy (higher is better)
			    "COMEX_WON","COMEX_SIZE", // Commercial – won & funnel size
			    "SPEC_PHASEAL","SPEC_IVA", // Marketing specifics – conversions (assumed higher is better)
			    "FC_EC","FC_DIST",     // Marketing forecasts (assumed higher vs target is better)
			    "SUP_ORD_IN","SUP_ORD_SHIP","SUP_ORD_DELIV" // Supply flow (assumed higher vs target is better)
			}  // higher = better
			
			VAR _negativePerfMetrics =
			   {
			
			    "SUP_ORD_OPEN",                        // Open orders
			    "SUP_BO_SUP","SUP_BO_DIST", "SUP_BO_SUPREV",            // Backorders
			
			    "QLT_C_VOL","QLT_C_OVER90","QLT_C_NUM","QLT_C_TAT",// Quality – lower is better
			    "PE_DELAY","PE_COMP",                  // Sustaining – delays/under-resourced
			    "COMEX_LOST"                           // Commercial – lost customers
			}
			
			-- Variance group: closer to target (± threshold) = GREEN; outside = RED
			VAR _variancePerfMetrics =
			{
			
			    "FC_SIOP", // SIOP – treat as closeness to plan (adjust if you prefer direction)
			    "FC_SKU",
			    "PROD_PPA"     // PPA – purchase price vs target (often “as close as possible”)
			}
			
			VAR _varianceThreshold = 0.05
			
			RETURN
			IF(
			    NOT _isDelta || ISBLANK(_delta),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        -- Variance-based: green if within band, else red
			        _metricKey IN _variancePerfMetrics && _absDiff <= _varianceThreshold, "#3D5C28",  -- dark green
			        _metricKey IN _variancePerfMetrics && _absDiff >  _varianceThreshold, "#B23E3E",  -- dark red
			
			        -- Positive performance: higher is better
			        _metricKey IN _positivePerfMetrics && _delta >  0, "#3D5C28",
			        _metricKey IN _positivePerfMetrics && _delta <= 0, "#B23E3E",
			
			        -- Negative performance: lower is better
			        _metricKey IN _negativePerfMetrics && _delta <  0, "#3D5C28",
			        _metricKey IN _negativePerfMetrics && _delta >= 0, "#B23E3E",
			
			        "#444444"
			    )
			)
			
			```
		displayFolder: Formatting
		lineageTag: 21d55e9e-aab6-4e6a-9337-a501e0f55dbd

